{
  "name": "tegaki",
  "version": "0.11.1",
  "type": "module",
  "description": "Framework-agnostic animated handwriting renderer with React, Svelte, Vue, SolidJS, Astro, and Web Components adapters",
  "keywords": [
    "handwriting",
    "animation",
    "svg",
    "react",
    "svelte",
    "vue",
    "solid",
    "astro",
    "web-components",
    "custom-elements",
    "font",
    "calligraphy",
    "stroke-order",
    "text-animation",
    "writing-animation"
  ],
  "homepage": "https://github.com/KurtGokhan/tegaki#readme",
  "bugs": {
    "url": "https://github.com/KurtGokhan/tegaki/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/KurtGokhan/tegaki.git",
    "directory": "packages/renderer"
  },
  "license": "MIT",
  "author": {
    "name": "Gokhan Kurt",
    "email": "krtgkn@gmail.com",
    "url": "https://gkurt.com"
  },
  "exports": {
    ".": {
      "tegaki@dev": "./src/index.ts",
      "source": "./src/index.ts",
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./core": {
      "tegaki@dev": "./src/core/index.ts",
      "source": "./src/core/index.ts",
      "types": "./dist/core/index.d.mts",
      "import": "./dist/core/index.mjs"
    },
    "./react": {
      "tegaki@dev": "./src/react/index.ts",
      "source": "./src/react/index.ts",
      "types": "./dist/react/index.d.mts",
      "import": "./dist/react/index.mjs"
    },
    "./svelte": {
      "tegaki@dev": "./src/svelte/index.ts",
      "source": "./src/svelte/index.ts",
      "svelte": "./src/svelte/index.ts",
      "default": "./src/svelte/index.ts"
    },
    "./vue": {
      "tegaki@dev": "./src/vue/index.ts",
      "source": "./src/vue/index.ts",
      "default": "./src/vue/index.ts"
    },
    "./solid": {
      "tegaki@dev": "./src/solid/index.ts",
      "source": "./src/solid/index.ts",
      "types": "./dist/solid/index.d.mts",
      "import": "./dist/solid/index.mjs"
    },
    "./wc": {
      "tegaki@dev": "./src/wc/index.ts",
      "source": "./src/wc/index.ts",
      "types": "./dist/wc/index.d.mts",
      "import": "./dist/wc/index.mjs"
    },
    "./astro": "./src/astro/TegakiRenderer.astro",
    "./fonts/caveat": {
      "tegaki@dev": "./fonts/caveat/bundle.ts",
      "source": "./fonts/caveat/bundle.ts",
      "types": "./dist/fonts/caveat/bundle.d.mts",
      "node": "./fonts/caveat/bundle.ts",
      "default": "./dist/fonts/caveat/bundle.mjs"
    },
    "./fonts/italianno": {
      "tegaki@dev": "./fonts/italianno/bundle.ts",
      "source": "./fonts/italianno/bundle.ts",
      "types": "./dist/fonts/italianno/bundle.d.mts",
      "node": "./fonts/italianno/bundle.ts",
      "default": "./dist/fonts/italianno/bundle.mjs"
    },
    "./fonts/tangerine": {
      "tegaki@dev": "./fonts/tangerine/bundle.ts",
      "source": "./fonts/tangerine/bundle.ts",
      "types": "./dist/fonts/tangerine/bundle.d.mts",
      "node": "./fonts/tangerine/bundle.ts",
      "default": "./dist/fonts/tangerine/bundle.mjs"
    },
    "./fonts/parisienne": {
      "tegaki@dev": "./fonts/parisienne/bundle.ts",
      "source": "./fonts/parisienne/bundle.ts",
      "types": "./dist/fonts/parisienne/bundle.d.mts",
      "node": "./fonts/parisienne/bundle.ts",
      "default": "./dist/fonts/parisienne/bundle.mjs"
    }
  },
  "files": [
    "dist/",
    "src/",
    "fonts/",
    "README.md",
    "LICENSE",
    "FONTS-LICENSE.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsdown",
    "prepack": "bun run build && bun ../../scripts/prepareForRelease.ts",
    "generate-fonts": "bun --filter tegaki-generator start generate Caveat --output ../renderer/fonts/caveat && bun --filter tegaki-generator start generate Italianno --output ../renderer/fonts/italianno && bun --filter tegaki-generator start generate Tangerine --output ../renderer/fonts/tangerine && bun --filter tegaki-generator start generate Parisienne --output ../renderer/fonts/parisienne"
  },
  "dependencies": {},
  "peerDependencies": {
    "react": ">=18",
    "svelte": ">=5",
    "vue": ">=3",
    "solid-js": ">=1"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "svelte": {
      "optional": true
    },
    "vue": {
      "optional": true
    },
    "solid-js": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "tsdown": "^0.21.8",
    "typescript": "^6.0.2"
  }
}
